DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://your-domain.com

# Database (leave empty for SQLite in development)
