# Django Backend
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,sciencebo.uk,www.sciencebo.uk
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://sciencebo.uk,https://www.sciencebo.uk
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://sciencebo.uk,https://www.sciencebo.uk
DJANGO_SERVE_MEDIA=0

# Database (leave empty for SQLite in development)
DATABASE_URL=postgres://formulas:password@db:5432/formulas

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_monthly_...
STRIPE_PRO_YEARLY_PRICE_ID=price_yearly_...

# Google OAuth (GIS / ID token flow only needs the client ID)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Frontend
FRONTEND_URL=https://sciencebo.uk
VITE_API_URL=https://sciencebo.uk/api
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Production (docker-compose.prod.yml)
DJANGO_SECRET_KEY=generate-a-real-secret-key
DOMAIN=sciencebo.uk
DB_PASSWORD=generate-a-real-password
