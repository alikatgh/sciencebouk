# Django Backend
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,scienbo.uk,www.scienbo.uk
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://scienbo.uk,https://www.scienbo.uk
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://scienbo.uk,https://www.scienbo.uk

# Database (leave empty for SQLite in development)
DATABASE_URL=postgres://formulas:password@db:5432/formulas

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Frontend
FRONTEND_URL=https://scienbo.uk
VITE_API_URL=https://scienbo.uk/api
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Production (docker-compose.prod.yml)
SECRET_KEY=generate-a-real-secret-key
DOMAIN=scienbo.uk
DB_PASSWORD=generate-a-real-password
